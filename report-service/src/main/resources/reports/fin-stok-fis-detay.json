  "sourceQuery": "SELECT SFR.STOCK_FIS_ROW_ID, SFR.FIS_ID, SFR.FIS_NUMBER, SFR.STOCK_ID, SFR.AMOUNT AS MIKTAR, SFR.UNIT, SFR.PRICE AS BIRIM_FIYAT, SFR.TOTAL AS TOPLAM, SFR.TOTAL_TAX AS KDV_TUTAR, SFR.NET_TOTAL AS NET_TUTAR, SFR.TAX AS KDV_ORAN, SFR.DISCOUNT1, SFR.LOT_NO, SFR.SPECT_VAR_NAME, SF.FIS_DATE, SF.FIS_TYPE, SF.FIS_DETAIL, SF.REF_NO, SF.LOCATION_OUT, SF.LOCATION_IN, SF.PROJECT_ID, ISNULL(SPC.PROCESS_CAT, 'Diger') AS ISLEM_KATEGORISI, P.PROJECT_HEAD AS PROJE_ADI FROM [{schema}].[STOCK_FIS_ROW] SFR WITH (NOLOCK) LEFT JOIN [{schema}].[STOCK_FIS] SF WITH (NOLOCK) ON SF.FIS_ID = SFR.FIS_ID LEFT JOIN [workcube_mikrolink_7].[SETUP_PROCESS_CAT] SPC WITH (NOLOCK) ON SPC.PROCESS_CAT_ID = SF.PROCESS_CAT LEFT JOIN [workcube_mikrolink].[PRO_PROJECTS] P WITH (NOLOCK) ON P.PROJECT_ID = SF.PROJECT_ID",
