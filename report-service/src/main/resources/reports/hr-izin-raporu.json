{
  "contractVersion": 1,
  "key": "hr-izin-raporu",
  "version": "1.0",
  "title": "İzin Raporu",
  "description": "Çalışan izin talepleri, onay durumları ve izin süreleri",
  "category": "İnsan Kaynakları",
  "sourceQuery": "SELECT OT.OFFTIME_ID, OT.EMPLOYEE_ID, OT.OFFTIMECAT_ID, OT.STARTDATE, OT.FINISHDATE, OT.WORK_STARTDATE, OT.TOTAL_HOURS, OT.VALID, OT.VALID_1, OT.VALID_2, OT.DETAIL, OT.IS_CANCEL, OT.IS_FROM_PDKS, OT.IN_OUT_ID, OT.RECORD_DATE, EP.OUR_COMPANY_ID AS [OUR_COMPANY_ID] FROM [workcube_mikrolink].[OFFTIME] OT WITH (NOLOCK) INNER JOIN [workcube_mikrolink].[EMPLOYEE_POSITIONS] EP WITH (NOLOCK) ON EP.EMPLOYEE_ID = OT.EMPLOYEE_ID AND EP.POSITION_ID = (SELECT TOP 1 EP2.POSITION_ID FROM [workcube_mikrolink].[EMPLOYEE_POSITIONS] EP2 WITH (NOLOCK) WHERE EP2.EMPLOYEE_ID = OT.EMPLOYEE_ID AND EP2.OUR_COMPANY_ID IS NOT NULL ORDER BY CASE WHEN EP2.POSITION_STATUS = 1 THEN 0 ELSE 1 END, EP2.IS_MASTER DESC, EP2.POSITION_ID DESC)",
  "sourceSchema": "workcube_mikrolink",
  "schemaMode": "static",
  "tenantBoundary": {
    "mode": "row",
    "scopeType": "COMPANY",
    "reason": "Row-level company filter on EMPLOYEE_POSITIONS.OUR_COMPANY_ID projected via the sourceQuery employee-position join (RC-004 v2 projectedJoin boundary)."
  },
