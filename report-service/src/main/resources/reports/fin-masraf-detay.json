    "reason": "Yearly partition rotation; schema name encodes year and tenant boundary"
  },
  "sourceQuery": "SELECT EIP.EXPENSE_ID, EIP.EXPENSE_DATE, EIP.DETAIL, EIP.PAPER_NO, EIP.SERIAL_NO, EIP.TOTAL_AMOUNT, EIP.KDV_TOTAL, EIP.TOTAL_AMOUNT_KDVLI, EIP.OTHER_MONEY, EIP.OTHER_MONEY_AMOUNT, EIP.OTHER_MONEY_KDV, EIP.OTHER_MONEY_NET_TOTAL, EIP.DUE_DATE, EIP.DEPARTMENT_ID, EIP.BRANCH_ID, EIP.PROJECT_ID, EIP.STOPAJ, EIP.STOPAJ_ORAN, EIP.IS_IPTAL, EIP.RECORD_DATE, EI.EXPENSE_ITEM_NAME AS GIDER_KALEMI, EI.ACCOUNT_CODE AS GIDER_HESAP_KODU, ISNULL(SPC.PROCESS_CAT, 'Diger') AS ISLEM_KATEGORISI, C.FULLNAME AS CARI_ADI, P.PROJECT_HEAD AS PROJE_ADI FROM [{schema}].[EXPENSE_ITEM_PLANS] EIP WITH (NOLOCK) LEFT JOIN [{schema}].[EXPENSE_ITEMS] EI WITH (NOLOCK) ON EI.EXPENSE_ITEM_ID = EIP.EXPENSE_COST_TYPE LEFT JOIN {tenantSetupProcessCatRelation} ON SPC.PROCESS_CAT_ID = EIP.PROCESS_CAT LEFT JOIN [workcube_mikrolink].[COMPANY] C WITH (NOLOCK) ON C.COMPANY_ID = EIP.CH_COMPANY_ID LEFT JOIN [workcube_mikrolink].[PRO_PROJECTS] P WITH (NOLOCK) ON P.PROJECT_ID = EIP.PROJECT_ID",
