  "sourceQuery": "SELECT CA.ACTION_ID, CA.ACTION_DATE, CA.ACTION_NAME, CA.ACTION_DETAIL, CA.ACTION_VALUE, CA.ACTION_CURRENCY_ID, CA.OTHER_MONEY, CA.OTHER_CASH_ACT_VALUE, CA.DUE_DATE, CA.PAPER_NO, CA.ACTION_ACCOUNT_CODE AS HESAP_KODU, CA.TO_CMP_ID, CA.FROM_CMP_ID, CA.INVOICE_ID, CA.PROJECT_ID, ISNULL(SPC.PROCESS_CAT, 'Diger') AS ISLEM_KATEGORISI, C_TO.FULLNAME AS ALACAKLI_CARI, C_FROM.FULLNAME AS BORCLU_CARI, P.PROJECT_HEAD AS PROJE_ADI FROM [{schema}].[CARI_ACTIONS] CA WITH (NOLOCK) LEFT JOIN [workcube_mikrolink_7].[SETUP_PROCESS_CAT] SPC WITH (NOLOCK) ON SPC.PROCESS_CAT_ID = CA.PROCESS_CAT LEFT JOIN [workcube_mikrolink].[COMPANY] C_TO WITH (NOLOCK) ON C_TO.COMPANY_ID = CA.TO_CMP_ID LEFT JOIN [workcube_mikrolink].[COMPANY] C_FROM WITH (NOLOCK) ON C_FROM.COMPANY_ID = CA.FROM_CMP_ID LEFT JOIN [workcube_mikrolink].[PRO_PROJECTS] P WITH (NOLOCK) ON P.PROJECT_ID = CA.PROJECT_ID",
